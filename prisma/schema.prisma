generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

// Comando: npx prisma db push - para criar a tabela no banco de dados
model user {
  id        Int        @id @default(autoincrement())
  name      String
  email     String     @unique
  status    Boolean    @default(true)
  role      Role       @default(USER)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  posts Post[]

  @@map ("users") //mapeia a tabela para "users" no banco de dados
}

model Post {
  id        Int         @id @default(autoincrement())
  title     String 
  sbtitle   String?
  content   String
  userId    Int         @map("user_id") //mapeia a tabela para "user_id" no banco de dados
  User      user        @relation(fields: [userId], references: [id])

  @@map("posts") //mapeia a tabela para "posts" no banco de dados
}